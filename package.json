{
  "name": "zee-lin-code",
  "version": "0.1.0",
  "private": true,
  "description": "Electron + React terminal-style AI workspace",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:renderer\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5073 && cross-env VITE_DEV_SERVER_URL=http://localhost:5073 electron .",
    "build": "vite build",
    "start": "electron .",
    "test": "cross-env ELECTRON_RUN_AS_NODE=1 electron --test src/**/*.test.js",
    "test:e2e": "pnpm build && playwright test"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.8.1",
    "chokidar": "^3.6.0",
    "electron-log": "^5.4.3",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-arborist": "^3.4.3",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.54.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "playwright": "^1.54.2",
    "vite": "^6.2.0",
    "wait-on": "^8.0.3"
  }
}
